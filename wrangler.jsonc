{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ghosxt",
  "compatibility_date": "2026-05-02",
  "main": "src/worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    // Built by scripts/build-dist.py — run it before `wrangler deploy`/`wrangler dev`.
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  }
}
